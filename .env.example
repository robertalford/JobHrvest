# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=jobharvest
POSTGRES_USER=jobharvest
POSTGRES_PASSWORD=change-me-in-production

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ─── Ollama (LLM) ────────────────────────────────────────────────────────────
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.1:8b

# ─── Crawling ────────────────────────────────────────────────────────────────
CRAWL_RATE_LIMIT_SECONDS=2.0
CRAWL_MAX_CONCURRENT=4
CRAWL_MAX_DEPTH=3
CRAWL_TIMEOUT_SECONDS=30
CRAWL_USER_AGENT=JobHarvest/1.0 (job-listing-research; contact@jobharvest.local)

# ─── Celery ──────────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=4

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_BASE_PATH=/storage
RAW_HTML_PATH=/storage/raw_html
SCREENSHOTS_PATH=/storage/screenshots

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=false

# ─── Codex App-Server ────────────────────────────────────────────────────────
CODEX_MODEL=gpt-5.3-codex
COMPANY_ENRICHMENT_WORKER_STATUS_FILE=/storage/company_enrichment/worker_status.json
COMPANY_ENRICHMENT_CODEX_TIMEOUT_SEC=120
COMPANY_ENRICHMENT_PAGE_FETCH_TIMEOUT_SEC=20
COMPANY_ENRICHMENT_WORKER_STALE_AFTER_SEC=90
COMPANY_ENRICHMENT_ROW_STALE_AFTER_SEC=300
COMPANY_ENRICHMENT_GLOBAL_MAX_CONCURRENCY=3
COMPANY_ENRICHMENT_PER_RUN_MAX_CONCURRENCY=2
COMPANY_ENRICHMENT_FETCH_MAX_CONCURRENCY=6
COMPANY_ENRICHMENT_MAX_INFLIGHT_ROWS=6
COMPANY_ENRICHMENT_WORKER_PROCESSES=1
COMPANY_ENRICHMENT_CACHE_TTL_HOURS=168
