# JobHarvest — TLS is handled upstream by Cloudflare + dorcas-caddy (*.alfords.xyz wildcard cert).
# This instance only needs to serve HTTP on port 9080 (the LAN reverse-proxy target).
:80 {
    # API must be matched before the catch-all
    handle /api/* {
        reverse_proxy api:8000
    }
    # Storage (uploaded files — screenshots etc.)
    handle /storage/* {
        reverse_proxy api:8000
    }
    handle /* {
        reverse_proxy frontend:80
    }
}
