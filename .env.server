# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=jobharvest
POSTGRES_USER=jobharvest
POSTGRES_PASSWORD=jh-moonlight-2026

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ─── Ollama (LLM) ────────────────────────────────────────────────────────────
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.1:70b
# Fast model for Layer 5 LLM extraction (handles ~80% of cases, escalates hard ones to OLLAMA_MODEL)
# Set to empty string to disable the fast layer (falls straight through to OLLAMA_MODEL)
OLLAMA_FAST_MODEL=llama3.1:8b

# ─── Crawling ────────────────────────────────────────────────────────────────
CRAWL_RATE_LIMIT_SECONDS=0.5    # 0.5s between requests to same domain (polite but fast)
CRAWL_MAX_CONCURRENT=4
CRAWL_MAX_DEPTH=3
CRAWL_TIMEOUT_SECONDS=20        # Fail faster on dead sites (was 30)
CRAWL_USER_AGENT=JobHarvest/1.0 (job-listing-research; contact@jobharvest.local)

# ─── Celery ──────────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=16
CELERY_ML_CONCURRENCY=8

# ─── Ollama parallel inference ────────────────────────────────────────────────
# With llama3.1:8b (4.9GB) on 8GB RAM: keep at 1
# With llama3.2:3b (2.0GB) on 8GB RAM: set to 2 for double throughput
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=2

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_BASE_PATH=/storage
RAW_HTML_PATH=/storage/raw_html
SCREENSHOTS_PATH=/storage/screenshots

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=false

# ─── Auth ────────────────────────────────────────────────────────────────────
SECRET_KEY=5f3b2cdeb14875b926479e544929a134419f8c458a55c4f8f4027f18fc3cf85e
